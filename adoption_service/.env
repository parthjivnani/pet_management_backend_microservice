# Copy to .env in each service folder (auth_user_service, species_service, pet_service, adoption_service)
# or create one .env at repo root and copy into each service.

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=pet_management
JWT_SECRET_KEY=petmanagementsecretkey
ALGORITHM=HS256

# Optional (auth_user_service)
ACCESS_TOKEN_EXPIRE_DAYS=7
SITE_URL=http://localhost:5173
